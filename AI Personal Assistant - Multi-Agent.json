      "typeVersion": 3.4,
      "position": [
        2736,
        3920
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Extract Message').first().json.userMessage }}",
        "options": {
          "systemMessage": "You are a task router. You MUST return ONLY a valid JSON object. Nothing else.\n\nRules:\n- If message contains words like \"email\", \"mail\", \"send\", \"inbox\", \"gmail\" → route = \"gmail\"\n- If message contains \"whatsapp\", \"send whatsapp\", \"whatsapp message\" → route = \"whatsapp\"\n- If message contains \"note\", \"notion\", \"task\", \"database\", \"create note\", \"add note\" → route = \"notion\"\n- Everything else → route = \"general\"\n\nExample output:\n{\"route\": \"gmail\", \"task\": \"send email to test@gmail.com subject Hello body Hi there\"}\n\nIMPORTANT: Return ONLY the JSON. No explanation. No other text. No markdown."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        2928,
        4096
      ],
      "id": "2c5dab0f-385b-4512-9671-0f08c6130e8c",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": "llama3.1:8b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        2928,
        4304
      ],
      "id": "022315a5-9e71-4564-99f1-8cc80f0cc890",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "PGWWzQDTbjiCVGpU",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get AI Agent output\nconst content = $input.first().json.output || \n                $input.first().json.message?.content || '';\n\nlet route = 'general';\nlet task = '';\n\n// Try to extract JSON even if surrounded by text\nconst jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n  try {\n    const parsed = JSON.parse(jsonMatch[0]);\n    route = parsed.route || 'general';\n    task = parsed.task || '';\n  } catch(e) {\n    route = 'general';\n  }\n}\n\n// Get user message safely\nconst originalMessage = $('Extract Message').first().json.userMessage || '';\n\n// Force route based on keywords if AI failed\nconst userMessage = originalMessage.toLowerCase();\nif (route === 'general' && userMessage) {\n  if (userMessage.includes('email') || \n      userMessage.includes('mail') || \n      userMessage.includes('gmail') ||\n      userMessage.includes('send email')) {\n    route = 'gmail';\n  } else if (userMessage.includes('whatsapp')) {\n    route = 'whatsapp';\n  } else if (userMessage.includes('notion') || \n             userMessage.includes('note') || \n             userMessage.includes('task')) {\n    route = 'notion';\n  }\n}\n\ntask = task || originalMessage;\n\nreturn {\n  route: route,\n  task: task,\n  chatId: $('Extract Message').first().json.chatId || '',\n  userName: $('Extract Message').first().json.userName || '',\n  userMessage: originalMessage\n};"
      },
      "id": "a47a36ca-c0f7-4e47-abd6-1db56cefc390",
      "name": "Parse Route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3168,
        3920
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.route }}",
        "rules": {
          "rules": [
            {
              "value2": "gmail"
            },
            {
              "value2": "whatsapp",
              "output": 1
            },
            {
              "value2": "notion",
              "output": 2
            },
            {
              "value2": "general",
              "output": 3
            }
          ]
        },
        "fallbackOutput": 3
      },
